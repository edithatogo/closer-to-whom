{
  "$defs": {
    "Formulation": {
      "description": "Anti-HER2 medicine formulation or combination.",
      "enum": [
        "trastuzumab_iv",
        "trastuzumab_sc",
        "phesgo_sc"
      ],
      "title": "Formulation",
      "type": "string"
    },
    "VisitType": {
      "additionalProperties": false,
      "description": "A visit component in a treatment pathway.",
      "properties": {
        "administration_minutes": {
          "minimum": 0.0,
          "title": "Administration Minutes",
          "type": "number"
        },
        "count": {
          "minimum": 0.0,
          "title": "Count",
          "type": "number"
        },
        "may_be_home": {
          "default": false,
          "title": "May Be Home",
          "type": "boolean"
        },
        "observation_minutes": {
          "minimum": 0.0,
          "title": "Observation Minutes",
          "type": "number"
        },
        "other_on_site_minutes": {
          "default": 0.0,
          "minimum": 0.0,
          "title": "Other On Site Minutes",
          "type": "number"
        },
        "requires_hospital": {
          "default": false,
          "title": "Requires Hospital",
          "type": "boolean"
        },
        "requires_resuscitation": {
          "default": false,
          "title": "Requires Resuscitation",
          "type": "boolean"
        },
        "visit_type_id": {
          "minLength": 1,
          "title": "Visit Type Id",
          "type": "string"
        }
      },
      "required": [
        "visit_type_id",
        "count",
        "administration_minutes",
        "observation_minutes"
      ],
      "title": "VisitType",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Clinical pathway represented at an aggregate course level.",
  "properties": {
    "clinically_reviewed": {
      "default": false,
      "title": "Clinically Reviewed",
      "type": "boolean"
    },
    "decision_cohort": {
      "minLength": 1,
      "title": "Decision Cohort",
      "type": "string"
    },
    "formulation": {
      "$ref": "#/$defs/Formulation"
    },
    "indication": {
      "enum": [
        "early",
        "metastatic"
      ],
      "title": "Indication",
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "pathway_id": {
      "minLength": 1,
      "title": "Pathway Id",
      "type": "string"
    },
    "source_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Source Ids",
      "type": "array"
    },
    "visits": {
      "items": {
        "$ref": "#/$defs/VisitType"
      },
      "minItems": 1,
      "title": "Visits",
      "type": "array"
    }
  },
  "required": [
    "pathway_id",
    "decision_cohort",
    "name",
    "indication",
    "formulation",
    "visits",
    "source_ids"
  ],
  "title": "Pathway",
  "type": "object"
}
